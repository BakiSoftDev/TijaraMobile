<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-background: #f0f4f8;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tijaramobile.controller.PurchaseFormController">
<VBox stylesheets="@../../../Img/styles.css"
      spacing="10" style="-fx-background-color:#f0f4f8;">
    <padding><Insets top="12" left="12" right="12" bottom="12"/></padding>

    <Label fx:id="lblTitle" text="%purchase.title" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#2c3e50;"/>

    <!-- Header fields -->
    <VBox spacing="8" styleClass="login-container">
        <padding><Insets top="10" left="10" right="10" bottom="10"/></padding>
        <HBox spacing="10">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="%purchase.num" style="-fx-text-fill:#555;-fx-font-size:11px;"/>
                <TextField fx:id="numField" promptText="FA-001" styleClass="text-field"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="Date" style="-fx-text-fill:#555;-fx-font-size:11px;"/>
                <DatePicker fx:id="dtPicker" maxWidth="1.7976931348623157E308" styleClass="date-picker"/>
            </VBox>
        </HBox>
        <Label text="%purchase.supplier" style="-fx-text-fill:#555;-fx-font-size:11px;"/>
        <ComboBox fx:id="fournisseurCombo" promptText="%purchase.supplier" maxWidth="1.7976931348623157E308" styleClass="combo-box"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <CheckBox fx:id="tvaCheck" text="TVA 20%" selected="true" style="-fx-text-fill:#333;"/>
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="Montant payé" style="-fx-text-fill:#555;-fx-font-size:11px;"/>
                <TextField fx:id="payeField" promptText="0.00" styleClass="text-field"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- Product search row with autocomplete -->
    <VBox spacing="0">
        <HBox spacing="8" alignment="CENTER_LEFT">
            <TextField fx:id="productSearch" promptText="%purchase.search" HBox.hgrow="ALWAYS" styleClass="text-field"/>
            <Button text="%btn.new" onAction="#handleNewProduct" styleClass="btn, btn-blue"/>
        </HBox>
        <ListView fx:id="suggestionList" managed="false" visible="false" styleClass="list-view"/>
    </VBox>

    <!-- Lines table -->
    <TableView fx:id="linesTable" VBox.vgrow="ALWAYS" minHeight="150" styleClass="table-view" style="-fx-border-color:transparent;">
        <columns>
            <TableColumn fx:id="colProd" text="%stock.col.name" minWidth="100"/>
            <TableColumn fx:id="colQnt" text="%stock.col.qnt" minWidth="45"/>
            <TableColumn fx:id="colPrix" text="%form.product.price_a" minWidth="65"/>
            <TableColumn fx:id="colTot" text="Total" minWidth="65"/>
            <TableColumn fx:id="colDel" text="" minWidth="45" prefWidth="45"/>
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>

    <Label fx:id="lblTotal" text="HT: 0.00  TVA: 0.00  TTC: 0.00" style="-fx-font-weight:bold;-fx-text-fill:#008037;-fx-font-size:13px;"/>
    <Label fx:id="errorLabel" textFill="RED" wrapText="true"/>

    <HBox spacing="10">
        <Button text="%btn.cancel" onAction="#handleCancel" styleClass="btn, btn-red" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
        <Button text="%btn.validate" onAction="#handleSave" styleClass="btn, btn-green" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
    </HBox>
</VBox>
</ScrollPane>
