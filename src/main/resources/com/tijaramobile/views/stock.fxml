<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tijaramobile.controller.StockController"
      spacing="0" style="-fx-background-color:#f0f4f8;" fillWidth="true">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color:white;-fx-border-color:transparent transparent #e9ecef transparent;-fx-border-width:0 0 1 0;" minHeight="52">
        <padding><Insets left="12" right="12" top="8" bottom="8"/></padding>
        <Label text="%stock.title" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#2c3e50;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="%btn.new" onAction="#handleAdd" styleClass="btn, btn-green"/>
    </HBox>

    <!-- Search -->
    <HBox spacing="8" style="-fx-background-color:white;" alignment="CENTER_LEFT">
        <padding><Insets left="12" right="12" top="8" bottom="8"/></padding>
        <TextField fx:id="searchField" promptText="%stock.search" HBox.hgrow="ALWAYS" styleClass="text-field" onAction="#handleSearch"/>
        <Button text="%stock.search" onAction="#handleSearch" styleClass="btn, btn-blue"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="table" VBox.vgrow="ALWAYS" style="-fx-border-color:transparent;" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colNom" text="%stock.col.name" minWidth="90" prefWidth="90"/>
            <TableColumn fx:id="colRef" text="%stock.col.ref" minWidth="60" prefWidth="60"/>
            <TableColumn fx:id="colUnit" text="Unit" minWidth="50" prefWidth="50"/>
            <TableColumn fx:id="colPrixV" text="%stock.col.price" minWidth="60" prefWidth="60"/>
            <TableColumn fx:id="colQnt" text="%stock.col.qnt" minWidth="50" prefWidth="50"/>
            <TableColumn fx:id="colPrixA" text="PA" minWidth="60" prefWidth="60"/>
            <TableColumn fx:id="colActions" text="" minWidth="80" prefWidth="80"/>
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>
</VBox>
