<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tijaramobile.controller.PurchaseController"
      spacing="0" style="-fx-background-color:#f0f4f8;" fillWidth="true">

    <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color:white;-fx-border-color:transparent transparent #e9ecef transparent;-fx-border-width:0 0 1 0;" minHeight="52">
        <padding><Insets left="12" right="12" top="8" bottom="8"/></padding>
        <Label text="🛒 Achats" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#2c3e50;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Nouvel Achat" onAction="#handleAdd" styleClass="btn, btn-green"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="table-view" style="-fx-border-color:transparent;">
        <columns>
            <TableColumn fx:id="colNum" text="N°" minWidth="70"/>
            <TableColumn fx:id="colFournisseur" text="Fournisseur" minWidth="90"/>
            <TableColumn fx:id="colDate" text="Date" minWidth="80"/>
            <TableColumn fx:id="colTotal" text="TTC" minWidth="65"/>
            <TableColumn fx:id="colPaye" text="Payé" minWidth="60"/>
            <TableColumn fx:id="colReste" text="Reste" minWidth="60"/>
            <TableColumn fx:id="colActions" text="" minWidth="80" prefWidth="80"/>
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>
</VBox>
