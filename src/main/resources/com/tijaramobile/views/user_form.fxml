<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tijaramobile.controller.UserFormController"
      stylesheets="@../../../Img/styles.css"
      spacing="12" style="-fx-background-color:#f0f4f8;">
    <padding><Insets top="16" left="16" right="16" bottom="16"/></padding>

    <Label fx:id="lblTitle" text="Utilisateur" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#2c3e50;"/>

    <VBox spacing="10" styleClass="login-container">
        <padding><Insets top="12" left="12" right="12" bottom="12"/></padding>
        <Label text="Nom Complet *" style="-fx-text-fill:#555;-fx-font-size:12px;"/>
        <TextField fx:id="fullNameField" promptText="Nom complet" styleClass="text-field"/>
        <Label text="Username *" style="-fx-text-fill:#555;-fx-font-size:12px;"/>
        <TextField fx:id="usernameField" promptText="username" styleClass="text-field"/>
        <Label text="Mot de passe *" style="-fx-text-fill:#555;-fx-font-size:12px;"/>
        <PasswordField fx:id="passwordField" promptText="(laisser vide pour conserver)" styleClass="text-field"/>
        <Label text="Email" style="-fx-text-fill:#555;-fx-font-size:12px;"/>
        <TextField fx:id="emailField" promptText="email@..." styleClass="text-field"/>
    </VBox>

    <Label fx:id="errorLabel" textFill="RED"/>
    <HBox spacing="10">
        <Button text="Annuler" onAction="#handleCancel" styleClass="btn, btn-red" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
        <Button text="Enregistrer" onAction="#handleSave" styleClass="btn, btn-green" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
    </HBox>
</VBox>
